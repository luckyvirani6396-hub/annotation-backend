# =============================================================================
# Annotation Studio — runtime configuration
# -----------------------------------------------------------------------------
# This file is read by `pydantic-settings` (see app/config/settings.py) and is
# the single source of truth for runtime configuration in development. Keep
# secrets out of version control: this file is listed in `.gitignore`.
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=Annotation Studio
APP_VERSION=1.0.0
DEBUG=False
HOST=0.0.0.0
PORT=9000

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://192.168.5.202:27017
DATABASE_NAME=annotation_db

# ── File upload ──────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE=1073741824
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png
UPLOAD_DIR=./uploads
# When MongoDB points at a remote server, set this to that API host so export
# can download /uploads/images/* over HTTP (local dev with shared database).
ASSET_BASE_URL=http://192.168.5.202:9000

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=./logs

# ── Authentication / JWT ─────────────────────────────────────────────────────
# In production replace JWT_SECRET with a long, high-entropy value, e.g.
#   PowerShell : [Convert]::ToBase64String((1..48|%{[byte](Get-Random -Max 256)}))
#   Linux/mac  : openssl rand -hex 48
JWT_SECRET=dev-secret-please-rotate-in-production-min-32-chars-3f1b8c4e7a92
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=120
JWT_REFRESH_TTL_DAYS=30

# CORS — comma-separated origins, or "*" for any (dev only)
CORS_ORIGINS=*

# ── Bootstrap admin account ──────────────────────────────────────────────────
# Created automatically on first boot if no user with this email exists.
# Change ADMIN_PASSWORD before exposing the service to anyone.
ADMIN_EMAIL=admin@annotation.studio
ADMIN_PASSWORD=Admin@2026!
ADMIN_FULL_NAME=Workspace Admin

# ── Flower (Celery monitoring) basic auth ──────────────────────────────────
FLOWER_BASIC_AUTH=admin:flower

# ── Redis / Celery (distributed task queue) ─────────────────────────────────
# When running with docker-compose, override REDIS_URL to redis://redis:6379/0
REDIS_URL=redis://192.168.5.202:6379/0
CELERY_BROKER_URL=redis://192.168.5.202:6379/1
CELERY_RESULT_BACKEND=redis://192.168.5.202:6379/2
CELERY_WORKER_CONCURRENCY=8
JOB_TTL_SECONDS=259200



# ── Frontend → backend wiring ──────────────────────────────────────────────
# Leave blank when serving the SPA behind the same nginx (relative /api works).
# In split-deploy mode, set to https://api.example.com.
REACT_APP_API_URL=http://192.168.5.202:9000