# Copy to .env and adjust for your environment.
# For Docker Compose: cp .env.example .env  (defaults below match service names)

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=Annotation Studio
APP_VERSION=1.0.0
DEBUG=False
HOST=0.0.0.0
PORT=9000

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Docker Compose: mongodb://mongo:27017
# MongoDB Atlas:  mongodb+srv://user:pass@cluster.mongodb.net
MONGODB_URL=mongodb://mongo:27017
DATABASE_NAME=annotation_db

# ── File upload ──────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE=1073741824
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.bmp,.webp
UPLOAD_DIR=./uploads
# Public API URL — required when worker/API run on different hosts (export fetches images over HTTP)
ASSET_BASE_URL=http://localhost:9000

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=./logs

# ── Authentication / JWT ─────────────────────────────────────────────────────
JWT_SECRET=change-me-generate-with-openssl-rand-hex-48
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=120
JWT_REFRESH_TTL_DAYS=30

CORS_ORIGINS=*

# ── Bootstrap admin (created on first boot if email does not exist) ──────────
ADMIN_EMAIL=admin@annotation.studio
ADMIN_PASSWORD=ChangeMeBeforeDeploy!
ADMIN_FULL_NAME=Workspace Admin

# ── Flower (Celery monitoring) ───────────────────────────────────────────────
FLOWER_BASIC_AUTH=admin:flower

# ── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_WORKER_CONCURRENCY=4
JOB_TTL_SECONDS=259200

# ── Frontend ─────────────────────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:9000
